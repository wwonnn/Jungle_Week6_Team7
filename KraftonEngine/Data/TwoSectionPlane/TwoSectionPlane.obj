# TwoSectionPlane.obj
mtllib TwoSectionPlane.mtl

# 1. 정점 (Vertices)
v -1.0  0.0  1.0
v  0.0  0.0  1.0
v  1.0  0.0  1.0
v -1.0  0.0 -1.0
v  0.0  0.0 -1.0
v  1.0  0.0 -1.0

# 2. 텍스처 좌표 (UV / vt)
vt 0.0 0.0
vt 0.5 0.0
vt 1.0 0.0
vt 0.0 1.0
vt 0.5 1.0
vt 1.0 1.0

# 3. 법선 벡터 (Normals / vn)
vn 0.0 1.0 0.0

# 4. 면 (Faces)
usemtl LeftMat
f 4/4/1 1/1/1 2/2/1
f 4/4/1 2/2/1 5/5/1

usemtl RightMat
f 5/5/1 2/2/1 3/3/1
f 5/5/1 3/3/1 6/6/1