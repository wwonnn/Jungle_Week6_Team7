# Simple Cube with normals and texcoords
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

vn  0  0 -1
vn  0  0  1
vn  1  0  0
vn -1  0  0
vn  0  1  0
vn  0 -1  0

vt 0 0
vt 1 0
vt 1 1
vt 0 1

# Front (-Z)
f 1/1/1 3/3/1 2/2/1
f 1/1/1 4/4/1 3/3/1
# Back (+Z)
f 5/1/2 6/2/2 7/3/2
f 5/1/2 7/3/2 8/4/2
# Right (+X)
f 2/1/3 3/4/3 7/3/3
f 2/1/3 7/3/3 6/2/3
# Left (-X)
f 5/1/4 8/4/4 4/3/4
f 5/1/4 4/3/4 1/2/4
# Top (+Y)
f 4/1/5 8/4/5 7/3/5
f 4/1/5 7/3/5 3/2/5
# Bottom (-Y)
f 5/1/6 1/4/6 2/3/6
f 5/1/6 2/3/6 6/2/6
